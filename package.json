{
  "name": "@mahidsec/nest",
  "version": "1.0.1",
  "description": "Standalone local course viewer with Moonlight themes",
  "type": "module",
  "bin": {
    "nest": "./bin/nest.js"
  },
  "scripts": {
    "build": "cd frontend && npm run build && cd .. && node esbuild.config.mjs",
    "dev:server": "tsx src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "dev": "npm run dev:server",
    "start": "node dist/server.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "open": "^10.1.0",
    "qrcode": "^1.5.4",
    "systray2": "^2.1.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.18",
    "esbuild": "^0.25.4",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "frontend/dist/",
    "assets/",
    "screenshots/"
  ]
}
